// Dev container for proto-viz: Node 22 (matches CI), no services needed —
// the app is fully client-side and the test suite runs under Node.
{
  "name": "proto-viz",
  "image": "mcr.microsoft.com/devcontainers/javascript-node:22",

  // Install dependencies and the extra tooling the gated CI jobs need
  // (tshark for `npm run test:tshark`, Chromium for `npm run test:e2e`) so
  // the whole verify matrix is reproducible locally. See postCreate.sh.
  "postCreateCommand": "bash .devcontainer/postCreate.sh",

  "forwardPorts": [5173, 4173],
  "portsAttributes": {
    "5173": { "label": "vite dev server" },
    "4173": { "label": "vite preview (production build)" }
  },

  "customizations": {
    "vscode": {
      "extensions": [
        "dbaeumer.vscode-eslint",
        "bradlc.vscode-tailwindcss",
        "vitest.explorer"
      ],
      "settings": {
        "typescript.tsdk": "node_modules/typescript/lib"
      }
    }
  }
}
